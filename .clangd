CompileFlags:
  Add:
    - -std=c++20
    - -Wall
    - -Wextra
    - -I./include
    - -I./include/adapter
    - -I./include/core
    - -I./include/net
    - -I./include/observability
    - -I./include/protocol
    - -I./third_party
    - -pthread
  CompilationDatabase: .
Diagnostics:
  UnusedIncludes: Strict
  MisleadingIndentation: true
Index:
  Background: Build
